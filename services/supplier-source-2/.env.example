# --- source-2-us — Mannapov LLC (https://buy.mannapovllc.com) ---
# Active feed. Sandbox + production credentials confirmed during the Phase 1
# supplier audit and provided by the Client (Agreement §4).
SUPPLIER_2_API_BASE=https://buy.mannapovllc.com/api
SUPPLIER_2_API_KEY=
SUPPLIER_2_SANDBOX=true

# --- source-2-dxb — Dubai wholesale (RESERVED slot) ---
# Inactive until Phase 1 names the supplier. The routing layer skips this
# feed while it is not enabled. The variables below are wired for the day
# the partner is signed; until then leave them blank.
SUPPLIER_DUBAI_MODE=rest                                # rest | csv | manual
SUPPLIER_DUBAI_API_BASE=https://<dxb-partner-host>/api
SUPPLIER_DUBAI_API_KEY=
SUPPLIER_DUBAI_MANUAL_DROPBOX=/var/lib/source-2-dxb/inbox
SUPPLIER_DUBAI_FX_USD_PER_AED=0.272                     # snapshot FX rate; rotated by ops

# Routing thresholds
ROUTING_WHOLESALE_QTY_THRESHOLD=100
ROUTING_EXPEDITED_DISABLE_DXB=true

# Stealth toggle
SCRAPLING_USE_STEALTH=true

# Supabase — service role. Required.
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# Cadence (production driven by pg_cron; these only used in --loop dev mode)
SYNC_INVENTORY_US_INTERVAL_SECONDS=600
SYNC_INVENTORY_DXB_INTERVAL_SECONDS=3600
SYNC_CATALOG_US_INTERVAL_SECONDS=21600
SYNC_CATALOG_DXB_INTERVAL_SECONDS=43200
