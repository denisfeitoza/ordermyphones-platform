# Supplier #1 — Assurant (https://www.assurant.com)
# Sandbox + production base URLs and credentials are confirmed during the
# Phase 1 supplier audit and provided by the Client (Agreement §4).
SUPPLIER_1_API_BASE=https://<assurant-partner-host>/api
SUPPLIER_1_API_KEY=
SUPPLIER_1_SHARED_SECRET=
SUPPLIER_1_SANDBOX=true

# Scrapling stealth toggle (set true for sites with bot protection)
SCRAPLING_USE_STEALTH=true

# Supabase — server-side service role. Required.
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# Sync cadence (only used in dev / --loop mode; production driven by pg_cron)
SYNC_INVENTORY_INTERVAL_SECONDS=600
SYNC_CATALOG_INTERVAL_SECONDS=21600
