# Anthropic (primary). Required.
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (fallback gateway). Optional.
OPENROUTER_API_KEY=

# Supabase — server-side service role. Required.
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# Service
PORT=8787

# Budgets (USD per request; per-day caps live in code/config)
MAX_REQUEST_COST_USD=0.50
