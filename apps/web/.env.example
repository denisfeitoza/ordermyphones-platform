# Public — exposed to the browser bundle. Never put server secrets here.
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Stripe publishable key (test / live). Restricted by domain in Stripe dashboard.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Observability
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# AI service base URL (proxied by Caddy at /ai/* in production)
VITE_AI_API_BASE=http://localhost:8787

# Build-time flags
VITE_SOURCEMAPS=false
